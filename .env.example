# admin-it environment variables
# Copy this file to .env in the repo root and fill in values for your environment.
# The root .env is read by Docker Compose; backend/.env is read by the backend process.

# ---------------------------------------------------------------------------
# CORS (backend)
# Comma-separated list of origins allowed to call the API.
# For local dev: http://localhost:3000
# For a deployed instance: https://admin.example.com
#
# NOTE: set this in the root .env (this file), not in backend/.env.
# Docker Compose's environment: block reads from the root .env and takes
# precedence over env_file: (backend/.env), so a value in backend/.env
# would be silently ignored.
# ---------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:3000

# ---------------------------------------------------------------------------
# Frontend proxy target (Docker Compose / local dev)
# The URL the Vite dev server proxies /api/* requests to.
# In Docker Compose this should be http://backend:8000 (the service name).
# For local dev outside Docker: http://localhost:8000
# ---------------------------------------------------------------------------
VITE_BACKEND_URL=http://backend:8000
